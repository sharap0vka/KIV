{
  "name": "site2026",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format:check": "biome format .",
    "format": "biome format --write .",
    "quality:check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "smoke:structure": "node scripts/smoke/check-structure.mjs",
    "smoke:config": "node scripts/smoke/check-config.mjs",
    "smoke:run": "node scripts/smoke/check-run.mjs",
    "smoke:all": "node scripts/smoke/check-structure.mjs && node scripts/smoke/check-config.mjs && node scripts/smoke/check-run.mjs",
    "docs:sync-context": "node scripts/context/generate-context-docs.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.7.2",
    "velite": "^0.2.4",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css,scss,mjs,cjs,yml,yaml}": "biome check --write"
  },
  "packageManager": "pnpm@10.12.1"
}
